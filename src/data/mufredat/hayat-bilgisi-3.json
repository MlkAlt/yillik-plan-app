        { "kod": "HB.3.2.2", "baslik": "Toplumsal çevre", "adimlar": ["Yaşadığı çevredeki kurumları (okul, sağlık ocağı, belediye) tanıtır.", "Bu kurumların topluma katkılarını açıklar."] }
